module fac(
  input a, b, cin, 
  output sum, cout
  );
  assign sum=(a^b^cin);
  assign cout=((a&b)|(b&cin)|(a&cin));
endmodule

module rca#(parameter w)(
  input [w-1:0]a,
  input [w-1:0]b,
  input cin,
  output reg [w-1:0]sum,
  output reg cout
  );
  wire [w:0]cin_aux;
  assign cin_aux[0]=cin;
  always @ (*) begin
      genvar i;
      generate
        for(i=0;i<w;i=i+1) begin: v
          fac f1(.a[i](a),.b[i](b),.cin(cin),sum[i](sum)
        end
      endgenerate
  end
endmodule