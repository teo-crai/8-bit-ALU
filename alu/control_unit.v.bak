module fsm(
    input clk, rst, b, e, load,
    input flag_mult, flag_div,
    input [1:0] op_code,
    output reg c_add, c_sub, c_mult, c_div,
    output reg write_enable
);
    localparam ST_RST       = 4'd0;
    localparam ST_LOAD      = 4'd1;
    localparam ST_DECODE    = 4'd2;
    localparam ST_ADD       = 4'd3;
    localparam ST_SUB       = 4'd4;
    localparam ST_MULT      = 4'd5;
    localparam ST_MULT_WAIT = 4'd9;
    localparam ST_DIV       = 4'd6;
    localparam ST_DIV_WAIT  = 4'd10;
    localparam ST_WRITE     = 4'd7;
    localparam ST_END       = 4'd8;

    reg [3:0] st, st_next;
    reg [1:0] op_latched;

    always @(posedge clk or posedge rst) begin
        if (rst) op_latched <= 2'b00;
        else if (load) op_latched <= op_code;
    end

    always @(posedge clk or posedge rst) begin
        if (rst) st <= ST_RST;
        else     st <= st_next;
    end

    always @(*) begin
        st_next = st;
        case(st)
            ST_RST:       if (b)          st_next = ST_LOAD;
            ST_LOAD:                      st_next = ST_DECODE;
            ST_DECODE:    case(op_latched)
                              2'b00: st_next = ST_ADD;
                              2'b01: st_next = ST_SUB;
                              2'b10: st_next = ST_MULT;
                              2'b11: st_next = ST_DIV;
                          endcase
            ST_ADD:                       st_next = ST_WRITE;
            ST_SUB:                       st_next = ST_WRITE;
            ST_MULT:                      st_next = ST_MULT_WAIT;
            ST_MULT_WAIT: if (!flag_mult) st_next = ST_WRITE;
            ST_DIV:                       st_next = ST_DIV_WAIT;
            ST_DIV_WAIT:  if (!flag_div)  st_next = ST_WRITE;
            ST_WRITE:     if (e)          st_next = ST_END;
            ST_END:       if (load)       st_next = ST_LOAD;
                          else if (b)     st_next = ST_LOAD;
            default:                      st_next = ST_RST;
        endcase
    end

    always @(*) begin
        {c_add, c_sub, c_mult, c_div} = 4'b0000;
        write_enable = 0;
        case(st)
            ST_ADD:       c_add  = 1;
            ST_SUB:       c_sub  = 1;
            ST_MULT,
            ST_MULT_WAIT: c_mult = 1;
            ST_DIV,
            ST_DIV_WAIT:  c_div  = 1;
            ST_WRITE: begin
                write_enable = 1;
                // Hold the active command signal during the write phase
                case(op_latched)
                    2'b00: c_add  = 1;
                    2'b01: c_sub  = 1;
                    2'b10: c_mult = 1;
                    2'b11: c_div  = 1;
                endcase
            end
        endcase
    end

endmodule