module multiplier(
  output [15:0]prod, //rezultatul final al produsului
  output flag_cnt, //semnaleaza starea modulului (1 = calcul in desfasurare; trece in 0 cand s-a obtinut rezultatul final)
  input [7:0]a, b, //numerele care se inmultesc
  input clk, start, rst //clk este pentru ciclul de tact si start este pentru a semnaliza inceperea inmutlirii, folosit pentru initializare
  );
  
  wire [7:0]A, Q, M; 
  wire [7:0]A_in, Q_in;  //valorile primite pe registrele de intrare
  wire Q_1; //bitul Q[-1] pentru stabilirea urmatoarei operatii efecutate in algoritm
  wire Q_1_next;
  wire [3:0]CNT; //contorul care indica cand se termina algoritmul
  wire [7:0]mux_out;

  assign flag_cnt = (CNT < 8); //flag-ul e pe 1 doar cand e algoritmul inca nu s-a terminat
  
  wire [7:0]sum, difference; //se pastreaza suma si diferenta efecutata la fiecare pas printr-un ripple carry adder
  
  wire [1:0]op_sel = {Q[0], Q_1}; //bitii 0 si -1 a lui Q decid urmatoarea operatie, deci ii salvam separat
  
  //modulul ripple carry adder e folosit pentru a realiza operatia de suma sau diferenta
  rca#(.w(8)) adder(.a(A), .b(M), .cin(1'b0), .sum(sum), .cout()); //suma se calculeaza normal, cu carry in 0
  rca#(.w(8)) subtracter(.a(A), .b(~M), .cin(1'b1), .sum(difference), .cout()); //diferenta se calculeaza complementand bitii lui M si cu carry in 1; practic se face adunarea dintre A si -M (transformat in C2)
  
  //decidem operatia 
  assign mux_out = (op_sel == 2'b01) ? sum : (op_sel == 2'b10) ? difference : A; 
  
  //se efectueaza un shift la dreapta
  wire [7:0]A_shifted = {mux_out[7], mux_out[7:1]};
  wire [7:0]Q_shifted = {mux_out[0], Q[7:1]};
  wire Q1_shifted = Q[0];
  
  //daca suntem la start, alegem datele de intrare, daca nu, datele shiftate
  mux2_1#(.w(8)) mux_A(.i0(A_shifted), .i1(8'b0), .sel(start), .out(A_in));
  mux2_1#(.w(8)) mux_Q(.i0(Q_shifted), .i1(b), .sel(start), .out(Q_in));
  mux2_1#(.w(1)) mux_Q1(.i0(Q1_shifted), .i1(1'b0), .sel(start), .out(Q_1_next));
  
  //registrul M se incarca doar la start
  register#(.w(8)) reg_M(.clk(clk), .load(start), .d(a), .q(M));
  
  wire ld_en = start | flag_cnt;
  
  //registrele se incarca la start sau in timpul calculului
  register#(.w(8)) reg_A(.clk(clk), .load(ld_en), .d(A_in), .q(A));
  register#(.w(8)) reg_Q(.clk(clk), .load(ld_en), .d(Q_in), .q(Q));
  register#(.w(1)) reg_Q1(.clk(clk), .load(ld_en), .d(Q_1_next), .q(Q_1));
  
  counter_4bit cnt(.clk(clk), .start(start), .under_8(flag_cnt), .count(CNT));
   
  wire done;
  assign done = (CNT == 4'd7); //activ doar cand am terminat cei 7 pasi

  register#(.w(16)) res_latch (.clk(clk), .load(done), .d({A_in, Q_in}), .q(prod));
  //produsul final se afla prin concatenarea lui A si Q
  //se încarca doar când done == 1
  
endmodule 
